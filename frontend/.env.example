# Supabase project connection (public by design — RLS is the security boundary).
# When absent, the site still builds and renders with a "not connected" banner.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Base path for GitHub Pages project sites; defaults to /polishuk-elections-2026/ when unset.
# VITE_BASE_PATH=/polishuk-elections-2026/
